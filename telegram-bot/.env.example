# ─────────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────────

# Your Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# ─────────────────────────────────────────────────────────────────────────────
# Translation backend — set ONE of the keys below
# ─────────────────────────────────────────────────────────────────────────────

# ✅ RECOMMENDED (FREE) — Google Gemini
# Get a free key at: https://aistudio.google.com/app/apikey
# Free limits: 15 requests/minute, 1500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — OpenAI (requires billing)
# Get key at: https://platform.openai.com/account/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Optional overrides
# ─────────────────────────────────────────────────────────────────────────────

# Force a specific translator: gemini | openai | dummy
# If not set, auto-selects based on which API key is present (Gemini takes priority)
# TRANSLATOR=gemini

# Maximum file size accepted (in megabytes). Default: 5
MAX_FILE_SIZE_MB=5

# Subtitle blocks per API call (default: 20). Higher = fewer API calls.
TRANSLATE_BATCH_SIZE=20

# Seconds to pause between batches (default: 0.3). Increase if hitting rate limits.
TRANSLATE_BATCH_DELAY=0.3
